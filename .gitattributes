# Auto detect text files and perform LF normalization
* text=auto

# Markdown documentation
*.md text eol=lf

# Source code
*.cs text eol=lf
*.cshtml text eol=lf
*.razor text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Configuration / data
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.ini text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Solution file traditionally uses CRLF
*.sln text eol=crlf

# Treat these as binary to prevent line ending conversion
*.dll binary
*.exe binary
*.pdb binary
*.so binary
*.dylib binary
*.cache binary
*.pkl binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
